# =====================================================================
# RESERVALO — Variables de entorno
# Copia este archivo a .env y rellena los valores reales
# =====================================================================

# -------------------------------------------------------------------
# BASE DE DATOS (Supabase PostgreSQL)
# -------------------------------------------------------------------
# Obtén las URLs en: Supabase Dashboard → Connect → Connection string
# IMPORTANTE: usa el Transaction Pooler (puerto 6543) para DATABASE_URL
#             y el Session Pooler (puerto 5432)  para DIRECT_URL
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# -------------------------------------------------------------------
# SUPABASE AUTH
# -------------------------------------------------------------------
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# -------------------------------------------------------------------
# AGENTE IA
# -------------------------------------------------------------------
# Proveedor: "gemini" (gratis) o "openai"
AI_PROVIDER="gemini"

# Gemini gratuito → https://aistudio.google.com/app/apikey
# OpenAI         → https://platform.openai.com/api-keys
AI_API_KEY="AIzaSy..."

# Modelo recomendado:
#   Gemini → gemini-2.5-flash
#   OpenAI → gpt-4o-mini
AI_MODEL="gemini-2.5-flash"

# -------------------------------------------------------------------
# APLICACIÓN
# -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Slug del negocio activo (debe existir en la tabla Business tras db:seed)
DEFAULT_BUSINESS_SLUG="demo"

# -------------------------------------------------------------------
# WHATSAPP (opcional — para recibir reservas por WhatsApp)
# -------------------------------------------------------------------
# Meta for Developers → WhatsApp → Configuration
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
