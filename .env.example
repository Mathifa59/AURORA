# ============================================================
# Bistro Aurora — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env a git (ya está en .gitignore).
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROJECT-ID.supabase.co

# Project Settings → API → anon / public key (empieza con sb_publishable_)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXX

# Project Settings → API → service_role key  [¡SECRETO!]
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Base de datos ─────────────────────────────────────────────
# Project Settings → Database → Connection string → Transaction pooler (puerto 6543)
# Añade ?pgbouncer=true&connection_limit=1 al final
DATABASE_URL=postgresql://postgres.TU-PROJECT-ID:TU-PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Project Settings → Database → Connection string → Direct connection (para migraciones)
DIRECT_URL=postgresql://postgres.TU-PROJECT-ID:TU-PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Inteligencia Artificial ───────────────────────────────────
# Proveedor: "gemini" (recomendado, gratis) o "openai"
AI_PROVIDER=gemini

# Gemini: https://aistudio.google.com/app/apikey
# OpenAI: https://platform.openai.com/api-keys
AI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo a usar (opcional — usa el default si no se especifica)
# Gemini: gemini-2.5-flash   OpenAI: gpt-4o-mini
# AI_MODEL=gemini-2.5-flash

# ── Negocio ───────────────────────────────────────────────────
# Slug del restaurante tal como está en la base de datos
DEFAULT_BUSINESS_SLUG=bistro-aurora

# ── App ───────────────────────────────────────────────────────
# URL pública del sitio (sin slash final)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# En producción: NEXT_PUBLIC_APP_URL=https://bistroaurora.mx

# ── WhatsApp Business (opcional) ─────────────────────────────
# Meta for Developers → Tu app → WhatsApp → API Setup
# WHATSAPP_VERIFY_TOKEN=token-que-tu-defines
# WHATSAPP_PHONE_NUMBER_ID=123456789012345
# WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
